# Application
APP_BASE_URL=http://localhost:3000
ANALYSIS_VERSION=poc-v1
LOG_LEVEL=info
PROVIDER_TIMEOUT_MS=10000
PROVIDER_RETRY_COUNT=2

# PostgreSQL / Neon (server only)
DATABASE_URL=

# Official GIS providers (server only; provision only after Stage 2 confirms use)
LINZ_DATA_SERVICE_API_KEY=
LINZ_BASEMAPS_API_KEY=
AUCKLAND_COUNCIL_API_KEY=

# Rate limiting (optional until selected)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Durable PDF storage (optional until selected)
BLOB_READ_WRITE_TOKEN=

# Optional narrative generation; deterministic reporting remains the default
AI_PROVIDER=none
OPENAI_API_KEY=
